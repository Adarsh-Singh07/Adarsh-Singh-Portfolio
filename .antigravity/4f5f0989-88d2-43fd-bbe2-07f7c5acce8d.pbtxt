  file_change {
    absolute_path_uri: "file:///src/components/RoleToggle.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport { motion } from \'motion/react\';\nimport { ProfileMode } from \'../types\';\nimport { Layers, Database } from \'lucide-react\';\n\ninterface RoleToggleProps {\n  currentMode: ProfileMode;\n  onModeChange: (mode: ProfileMode) => void;\n  isDark: boolean;\n}\n\nexport default function RoleToggle({ currentMode, onModeChange, isDark }: RoleToggleProps) {\n  // Roles defined dynamically to remain future-proof and support new inclusions easily\n  const roles: { id: ProfileMode; label: string; icon: any }[] = [\n    { id: \'general\', label: \'General AI/Data\', icon: Layers },\n    { id: \'data-engineer\', label: \'Data Engineer\', icon: Database }\n  ];\n\n  return (\n    <div \n      id=\"profile-mode-selector\"\n      className={`relative p-1 rounded-full flex gap-1 select-none transition-colors duration-500 ${\n        isDark \n          ? \'bg-neutral-900/90 border border-white/5\' \n          : \'bg-neutral-200/60 border border-black/5\'\n      }`}\n    >\n      {roles.map((role) => {\n        const IconComponent = role.icon;\n        const isActive = currentMode === role.id;\n\n        return (\n          <button\n            key={role.id}\n            id={`toggle-${role.id}`}\n            onClick={() => onModeChange(role.id)}\n            className={`relative px-4 py-1.5 rounded-full flex items-center gap-1.5 text-xs font-medium transition-all duration-300 focus:outline-none cursor-pointer ${\n              isActive \n                ? isDark ? \'text-white\' : \'text-neutral-900\' \n                : isDark ? \'text-slate-400 hover:text-slate-200\' : \'text-slate-500 hover:text-slate-900\'\n            }`}\n          >\n            {/* Smooth sliding active background container */}\n            {isActive && (\n              <motion.div\n                layoutId=\"activeRoleGlow\"\n                className={`absolute inset-0 rounded-full z-0 ${\n                  isDark \n                    ? \'bg-neutral-800 border border-white/10 shadow-[0_4px_12px_rgba(0,0,0,0.4)]\' \n                    : \'bg-white border border-slate-200 shadow-[0_4px_12px_rgba(0,0,0,0.06)]\'\n                }`}\n                transition={{ type: \'spring\', stiffness: 380, damping: 30 }}\n              />\n            )}\n            \n            <IconComponent className=\"w-3.5 h-3.5 relative z-10\" />\n            <span className=\"relative z-10 font-display tracking-wider whitespace-nowrap\">{role.label}</span>\n          </button>\n        );\n      })}\n    </div>\n  );\n}\n"
    }
