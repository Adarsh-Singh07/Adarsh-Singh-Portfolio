               <h4 className=\"text-xl font-bold font-display tracking-tight mb-2.5 transition-colors group-hover:text-sky-400\">\n                    {proj.title}\n                  </h4>\n\n                  <p className={`text-xs font-light leading-relaxed mb-5 ${\n                    isDark ? \'text-slate-400\' : \'text-slate-600\'\n                  }`}>\n                    {proj.description}\n                  </p>\n\n                  <div className=\"flex flex-wrap gap-1.5 mb-6\">\n                    {proj.technologies.map((t) => (\n                      <span \n                        key={t}\n                        className={`text-[10px] font-semibold font-mono tracking-wider px-2 py-0.5 rounded ${\n                          isDark ? \'bg-neutral-800 text-slate-400\' : \'bg-slate-100 text-slate-600\'\n                        }`}\n                      >\n                        {t}\n                      </span>\n                    ))}\n                  </div>\n                </div>\n\n                <div className=\"border-t border-neutral-800/10 dark:border-white/5 pt-4 flex items-center justify-between\">\n                  <div className=\"flex gap-4\">\n                    {proj.metrics.slice(0, 1).map((m) => (\n                      <div key={m.label}>\n                        <span className={`text-xs font-mono font-bold block ${isDark ? \'text-sky-400\' : \'text-indigo-600\'}`}>{m.value}</span>\n                        <span className={`text-[9px] uppercase font-mono block ${isDark ? \'text-slate-600\' : \'text-slate-400\'}`}>{m.label}</span>\n                      </div>\n                    ))}\n                  </div>\n\n                  <a\n                    href={proj.githubUrl}\n                    target=\"_blank\"\n                    rel=\"noreferrer\"\n                    className={`p-2 rounded-full cursor-pointer transition-colors ${\n                      isDark ? \'bg-neutral-800 text-white hover:bg-neutral-700\' : \'bg-slate-100 text-slate-800 hover:bg-slate-200\'\n                    }`}\n                  >\n                    <ExternalLink className=\"w-4 h-4\" />\n                  </a>\n                </div>\n              </motion.div>\n            ))}\n          </div>\n\n        </div>"
