    instruction: "Update Contacts & Footer layout to use premium sleek corners, system-blue details, elegant typography, and prestige aesthetics"
    replacement_infos {
      original_chunk {
        target_content: "        {/* Step 5 Title Header */}\n        <div className=\"mb-16 text-left max-w-3xl\">\n          <div className=\"flex items-center gap-2 mb-3\">\n            <span className={`w-8 h-[1px] ${isDark ? \'bg-indigo-400\' : \'bg-indigo-600\'}`} />\n            <span className={`text-[11px] font-mono tracking-widest font-bold uppercase ${\n              isDark ? \'text-indigo-400\' : \'text-indigo-600\'\n            }`}>\n              Secure Client Transmission Gateway\n            </span>\n          </div>\n          <h2 className=\"text-4xl md:text-5xl font-display font-extrabold tracking-tight\">\n            Let\342\200\231s Build Something Intelligent\n          </h2>\n          <p className={`mt-3.5 text-base md:text-lg font-light ${\n            isDark ? \'text-slate-400\' : \'text-slate-600\'\n          }`}>\n            Whether it\342\200\231s AI integration, custom high-throughput Data Engineering, or distributed systems \342\200\223 let\342\200\231s create meaningful impact.\n          </p>\n        </div>\n\n        {/* Form and Contact Cards Layout Grid */}\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-start\" id=\"interactive-contact-anchor\">\n          \n          {/* Left Side: Contact Cards */}\n          <div className=\"lg:col-span-5 space-y-4\">\n            {contactCards.map((card) => {\n              const IconComp = card.icon;\n              const isLink = !!card.href;\n\n              const CardBody = (\n                <div \n                  className={`p-5 rounded-2xl border flex items-center gap-4 transition-all duration-300 w-full text-left h-full ${\n                    isDark \n                      ? \'bg-neutral-950 border-neutral-900 text-white hover:bg-neutral-900 hover:border-neutral-800\' \n                      : \'bg-slate-50 border-slate-200 text-neutral-900 hover:bg-white hover:shadow-md\'\n                  }`}\n                >\n                  <div className={`p-3 rounded-xl ${\n                    isDark ? \'bg-neutral-900 border border-white/5 text-sky-400\' : \'bg-white border border-slate-100 text-indigo-700\'\n                  }`}>\n                    <IconComp className=\"w-5 h-5\" />\n                  </div>\n                  <div className=\"truncate\">\n                    <span className={`text-[10px] uppercase font-mono tracking-wider block ${\n                      isDark ? \'text-slate-500\' : \'text-slate-400\'\n                    }`}>\n                      {card.title}\n                    </span>\n                    <span className=\"text-sm font-semibold truncate font-display block\">{card.value}</span>\n                    <span className={`text-[10px] font-mono mt-0.5 block ${\n                      isDark ? \'text-slate-600\' : \'text-slate-500\'\n                    }`}>\n                      {card.label}\n                    </span>\n                  </div>\n                </div>\n              );\n\n              if (isLink) {\n                return (\n                  <a \n                    key={card.title} \n                    href={card.href} \n                    target=\"_blank\" \n                    rel=\"noreferrer\" \n                    className=\"block hover:-translate-y-0.5 transition-transform duration-300 select-none\"\n                  >\n                    {CardBody}\n                  </a>\n                );\n              }\n\n              return (\n                <div key={card.title} className=\"select-none\">\n                  {CardBody}\n                </div>\n              );\n            })}\n\n            {/* Resume button request box */}\n            <div className={`p-6 rounded-2xl border ${\n              isDark ? \'bg-neutral-950 border-neutral-900/60\' : \'bg-slate-50 border-slate-200/80\'\n            }`}>\n              <h4 className=\"text-sm font-bold font-display tracking-tight mb-2\">Architectural Blueprint Ready</h4>\n              <p className={`text-xs font-light leading-relaxed mb-4 ${isDark ? \'text-slate-500\' : \'text-slate-600\'}`}>\n                Grab my comprehensive qualifications catalog containing custom performance indexes, cloud architectures and code bases.\n              </p>\n              <a\n                href=\"mailto:adarsh2001gop@gmail.com?subject=Resume%20Request%20-%20AI%20%26%20Data%20Engineer\"\n                className={`py-2 px-4 rounded-xl text-xs font-semibold tracking-wider uppercase inline-flex items-center gap-1.5 transition-all duration-300 cursor-pointer ${\n                  isDark \n                    ? \'bg-neutral-900 hover:bg-neutral-800 text-white border border-neutral-850\' \n                    : \'bg-white hover:bg-slate-100 text-slate-800 border border-slate-300\'\n                }`}\n              >\n                <FileText className=\"w-3.5 h-3.5\" />\n                <span>View Full Blueprint Resume</span>\n                <ArrowUpRight className=\"w-3 h-3\" />\n              </a>\n            </div>\n          </div>\n\n          {/* Right Side: Luxury Contact Form */}\n          <div className=\"lg:col-span-7\">\n            <div className={`p-6 md:p-8 rounded-3xl border ${\n              isDark ? \'glass-card-dark\' : \'glass-card-light\'\n            }`}>\n              <h3 className=\"text-xl font-display font-extrabold tracking-tight mb-6\">\n                Transmit Secure Message\n              </h3>\n\n              <form onSubmit={handleFormSubmit} className=\"space-y-4\">\n                <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                  <div className=\"space-y-1.5 text-left\">\n                    <label htmlFor=\"name\" className={`text-[10px] font-mono uppercase tracking-wider block font-semibold ${\n                      isDark ? \'text-slate-400\' : \'text-slate-500\'\n                    }`}>\n                      Full Identity *\n                    </label>\n                    <input\n                      required\n                      type=\"text\"\n                      name=\"name\"\n                      id=\"name\"\n                      value={formData.name}\n                      onChange={handleInputChange}\n                      placeholder=\"e.g. Recruiter, CTO\"\n                      className={`w-full px-4 py-3 rounded-xl text-sm border focus:outline-none transition-all duration-300 ${\n                        isDark \n                          ? \'bg-neutral-900 border-neutral-800 text-white placeholder-slate-650 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500/25\' \n                          : \'bg-white border-slate-200 text-neutral-900 placeholder-slate-400 focus:border-indigo-600 focus:ring-1 focus:ring-indigo-600/20\'\n                      }`}\n                    />\n                  </div>\n\n                  <div className=\"space-y-1.5 text-left\">\n                    <label htmlFor=\"email\" className={`text-[10px] font-mono uppercase tracking-wider block font-semibold ${\n                      isDark ? \'text-slate-400\' : \'text-slate-500\'\n                    }`}>\n                      Secure Email *\n                    </label>\n                    <input\n                      required\n                      type=\"email\"\n                      name=\"email\"\n                      id=\"email\"\n                      value={formData.email}\n                      onChange={handleInputChange}\n                      placeholder=\"e.g. contact@company.com\"\n                      className={`w-full px-4 py-3 rounded-xl text-sm border focus:outline-none transition-all duration-300 ${\n                        isDark \n                          ? \'bg-neutral-900 border-neutral-800 text-white placeholder-slate-650 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500/25\' \n                          : \'bg-white border-slate-200 text-neutral-900 placeholder-slate-400 focus:border-indigo-600 focus:ring-1 focus:ring-indigo-600/20\'\n                      }`}\n                    />\n                  </div>\n                </div>\n\n                <div className=\"space-y-1.5 text-left\">\n                  <label htmlFor=\"subject\" className={`text-[10px] font-mono uppercase tracking-wider block font-semibold ${\n                    isDark ? \'text-slate-400\' : \'text-slate-500\'\n                  }`}>\n                    Subject Matter\n                  </label>\n                  <input\n                    type=\"text\"\n                    name=\"subject\"\n                    id=\"subject\"\n                    value={formData.subject}\n                    onChange={handleInputChange}\n                    placeholder=\"e.g. System Integration Request\"\n                    className={`w-full px-4 py-3 rounded-xl text-sm border focus:outline-none transition-all duration-300 ${\n                      isDark \n                        ? \'bg-neutral-900 border-neutral-800 text-white placeholder-slate-650 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500/25\' \n                        : \'bg-white border-slate-200 text-neutral-900 placeholder-slate-400 focus:border-indigo-600 focus:ring-1 focus:ring-indigo-600/20\'\n                    }`}\n                  />\n                </div>\n\n                <div className=\"space-y-1.5 text-left\">\n                  <label htmlFor=\"message\" className={`text-[10px] font-mono uppercase tracking-wider block font-semibold ${\n                    isDark ? \'text-slate-400\' : \'text-slate-500\'\n                  }`}>\n                    System Parameters (Message) *\n                  </label>\n                  <textarea\n                    required\n                    name=\"message\"\n                    id=\"message\"\n                    rows={4}\n                    value={formData.message}\n                    onChange={handleInputChange}\n                    placeholder=\"Specify project architectures, timeline variables or corporate proposal requirements...\"\n                    className={`w-full px-4 py-3 rounded-xl text-sm border focus:outline-none transition-all duration-300 resize-none ${\n                      isDark \n                        ? \'bg-neutral-900 border-neutral-800 text-white placeholder-slate-650 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500/25\' \n                        : \'bg-white border-slate-200 text-neutral-900 placeholder-slate-400 focus:border-indigo-600 focus:ring-1 focus:ring-indigo-600/20\'\n                    }`}\n                  />\n                </div>\n\n                {/* Submit button with loading triggers */}\n                <button\n                  id=\"submit-contact-button\"\n                  type=\"submit\"\n                  disabled={isSubmitting}\n                  className={`w-full py-4 px-6 rounded-2xl text-xs font-semibold tracking-widest uppercase flex items-center justify-center gap-2 cursor-pointer transition-all duration-300 border focus:outline-none ${\n                    isSubmitting \n                      ? \'bg-neutral-800 border-neutral-700 text-slate-400 pointer-events-none\' \n                      : isDark \n                        ? \'bg-white text-black border-transparent hover:bg-neutral-150\' \n                        : \'bg-neutral-900 text-white border-transparent hover:bg-neutral-800\'\n                  }`}\n                >\n                  {isSubmitting ? (\n                    <>\n                      <Loader2 className=\"w-4 h-4 animate-spin\" />\n                      <span>Transmitting Blueprint Data...</span>\n                    </>\n                  ) : (\n                    <>\n                      <Send className=\"w-3.5 h-3.5\" />\n                      <span>Send Transmission</span>\n                    </>\n                  )}\n                </button>\n\n                {/* Interactive Results Screen alert */}\n                {submitResult && (\n                  <motion.div\n                    initial={{ opacity: 0, y: 10 }}\n                    animate={{ opacity: 1, y: 0 }}\n                    className={`p-4 rounded-xl text-xs flex items-start gap-2.5 border mt-4 ${\n                      submitResult.success\n                        ? \'bg-emerald-500/5 text-emerald-400 border-emerald-500/10\'\n                        : \'bg-rose-500/5 text-rose-400 border-rose-500/10\'\n                    }`}\n                  >\n                    <CheckCircle2 className=\"w-4 h-4 shrink-0 mt-0.5\" />\n                    <span>{submitResult.message}</span>\n                  </motion.div>\n                )}\n              </form>\n            </div>\n          </div>\n\n        </div>\n\n        {/* Minimal Premium Footer */}\n        <div className={`mt-24 pt-8 border-t flex flex-col md:flex-row items-center justify-between gap-4 select-none ${\n          isDark ? \'border-neutral-900 text-slate-500\' : \'border-slate-100 text-slate-400\'\n        }`}>\n          <div className=\"text-xs font-mono\">\n            \302\251 2026 Adarsh Singh. All Systems Operational.\n          </div>\n          <div className=\"flex items-center gap-1 text-[11px] font-mono tracking-widest uppercase\">\n            <span>Crafted with precision</span>\n            <Clock className=\"w-3.5 h-3.5 text-indigo-500 font-extrabold\" />\n          </div>\n        </div>"
        replacement_content: "        {/* Step 5 Title Header */}\n        <div className=\"mb-16 text-left max-w-3xl\">\n          <div className=\"flex items-center gap-2 mb-3\">\n            <span className=\"w-8 h-[1px] bg-[#007AFF]\" />\n            <span className=\"text-[10px] font-bold uppercase tracking-[0.2em] text-[#007AFF]\">\n              Secure Client Transmission Gateway\n            </span>\n          </div>\n          <h2 className=\"text-4xl md:text-5xl font-sans font-semibold tracking-tight\">\n            Let\342\200\231s Build Something Intelligent\n          </h2>\n          <p className={`mt-3.5 text-base md:text-lg font-light ${\n            isDark ? \'text-white/50\' : \'text-neutral-950/60\'\n          }`}>\n            Whether it\342\200\231s AI integration, custom high-throughput Data Engineering, or distributed systems \342\200\223 let\342\200\231s create meaningful impact.\n          </p>\n        </div>\n\n        {/* Form and Contact Cards Layout Grid */}\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-start\" id=\"interactive-contact-anchor\">\n          \n          {/* Left Side: Contact Cards */}\n          <div className=\"lg:col-span-5 space-y-4\">\n            {contactCards.map((card) => {\n              const IconComp = card.icon;\n              const isLink = !!card.href;\n\n              const CardBody = (\n                <div \n                  className={`p-5 rounded-[24px] border flex items-center gap-4 transition-all duration-300 w-full text-left h-full ${\n                    isDark \n                      ? \'bg-[#151515]/60 border-white/5 text-white hover:bg-[#151515] hover:border-[#007AFF]/35\' \n                      : \'bg-slate-50 border-neutral-200/60 text-neutral-900 hover:bg-white hover:shadow-md\'\n                  }`}\n                >\n                  <div className={`p-3 rounded-2xl ${\n                    isDark ? \'bg-white/5 border border-white/5 text-[#007AFF]\' : \'bg-slate-100 border border-slate-250 text-[#007AFF]\'\n                  }`}>\n                    <IconComp className=\"w-4 h-4\" />\n                  </div>\n                  <div className=\"truncate\">\n                    <span className={`text-[9px] uppercase font-sans tracking-widest font-bold block ${\n                      isDark ? \'text-white/30\' : \'text-neutral-400\'\n                    }`}>\n                      {card.title}\n                    </span>\n                    <span className=\"text-sm font-semibold truncate font-sans block mt-0.5\">{card.value}</span>\n                    <span className={`text-[10px] font-serif italic mt-0.5 block ${\n                      isDark ? \'text-white/40\' : \'text-neutral-500\'\n                    }`}>\n                      {card.label}\n                    </span>\n                  </div>\n                </div>\n              );\n\n              if (isLink) {\n                return (\n                  <a \n                    key={card.title} \n                    href={card.href} \n                    target=\"_blank\" \n                    rel=\"noreferrer\" \n                    className=\"block hover:-translate-y-0.5 transition-transform duration-300 select-none\"\n                  >\n                    {CardBody}\n                  </a>\n                );\n              }\n\n              return (\n                <div key={card.title} className=\"select-none\">\n                  {CardBody}\n                </div>\n              );\n            })}\n\n            {/* Resume button request box */}\n            <div className={`p-6 rounded-[24px] border ${\n              isDark ? \'bg-[#151515]/60 border-white/5\' : \'bg-slate-50 border-neutral-200/60\'\n            }`}>\n              <h4 className=\"text-sm font-semibold font-sans tracking-tight mb-2\">Architectural Blueprint Ready</h4>\n              <p className={`text-xs font-light leading-relaxed mb-4 ${isDark ? \'text-white/50\' : \'text-neutral-950/60\'}`}>\n                Grab my comprehensive qualifications catalog containing custom performance indexes, cloud architectures and code bases.\n              </p>\n              <a\n                href=\"mailto:adarsh2001gop@gmail.com?subject=Resume%20Request%20-%20AI%20%26%20Data%20Engineer\"\n                className={`py-2 px-4 rounded-xl text-xs font-bold tracking-wider uppercase inline-flex items-center gap-1.5 transition-all duration-300 cursor-pointer ${\n                  isDark \n                    ? \'bg-white/5 hover:bg-[#007AFF]/20 text-white border border-white/5 hover:border-[#007AFF]/30\' \n                    : \'bg-white hover:bg-slate-100 text-slate-800 border border-slate-300\'\n                }`}\n              >\n                <FileText className=\"w-3.5 h-3.5\" />\n                <span>View Full Blueprint Resume</span>\n                <ArrowUpRight className=\"w-3 h-3 text-[#007AFF]\" />\n              </a>\n            </div>\n          </div>\n\n          {/* Right Side: Luxury Contact Form */}\n          <div className=\"lg:col-span-7\">\n            <div className={`p-6 md:p-8 rounded-[32px] border ${\n              isDark \n                ? \'bg-[#151515]/60 hover:bg-[#151515] border-white/5\' \n                : \'glass-card-light\'\n            }`}>\n              <h3 className=\"text-xl font-sans font-semibold tracking-tight mb-6\">\n                Transmit Secure Message\n              </h3>\n\n              <form onSubmit={handleFormSubmit} className=\"space-y-4\">\n                <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                  <div className=\"space-y-1.5 text-left\">\n                    <label htmlFor=\"name\" className={`text-[10px] font-sans uppercase tracking-[0.15em] block font-bold ${\n                      isDark ? \'text-white/40\' : \'text-neutral-500\'\n                    }`}>\n                      Full Identity *\n                    </label>\n                    <input\n                      required\n                      type=\"text\"\n                      name=\"name\"\n                      id=\"name\"\n                      value={formData.name}\n                      onChange={handleInputChange}\n                      placeholder=\"e.g. Recruiter, CTO\"\n                      className={`w-full px-4 py-3 rounded-xl text-sm border focus:outline-none transition-all duration-300 ${\n                        isDark \n                          ? \'bg-neutral-900 border-white/5 text-white placeholder-white/20 focus:border-[#007AFF] focus:ring-1 focus:ring-[#007AFF]/25\' \n                          : \'bg-white border-slate-200 text-neutral-900 placeholder-slate-400 focus:border-[#007AFF] focus:ring-1 focus:ring-[#007AFF]/20\'\n                      }`}\n                    />\n                  </div>\n\n                  <div className=\"space-y-1.5 text-left\">\n                    <label htmlFor=\"email\" className={`text-[10px] font-sans uppercase tracking-[0.15em] block font-bold ${\n                      isDark ? \'text-white/40\' : \'text-neutral-500\'\n                    }`}>\n                      Secure Email *\n                    </label>\n                    <input\n                      required\n                      type=\"email\"\n                      name=\"email\"\n                      id=\"email\"\n                      value={formData.email}\n                      onChange={handleInputChange}\n                      placeholder=\"e.g. contact@company.com\"\n                      className={`w-full px-4 py-3 rounded-xl text-sm border focus:outline-none transition-all duration-300 ${\n                        isDark \n                          ? \'bg-neutral-900 border-white/5 text-white placeholder-white/20 focus:border-[#007AFF] focus:ring-1 focus:ring-[#007AFF]/25\' \n                          : \'bg-white border-slate-200 text-neutral-900 placeholder-slate-400 focus:border-[#007AFF] focus:ring-1 focus:ring-[#007AFF]/20\'\n                      }`}\n                    />\n                  </div>\n                </div>\n\n                <div className=\"space-y-1.5 text-left\">\n                  <label htmlFor=\"subject\" className={`text-[10px] font-sans uppercase tracking-[0.15em] block font-bold ${\n                    isDark ? \'text-white/40\' : \'text-neutral-500\'\n                  }`}>\n                    Subject Matter\n                  </label>\n                  <input\n                    type=\"text\"\n                    name=\"subject\"\n                    id=\"subject\"\n                    value={formData.subject}\n                    onChange={handleInputChange}\n                    placeholder=\"e.g. System Integration Request\"\n                    className={`w-full px-4 py-3 rounded-xl text-sm border focus:outline-none transition-all duration-300 ${\n                      isDark \n                        ? \'bg-neutral-900 border-white/5 text-white placeholder-white/20 focus:border-[#007AFF] focus:ring-1 focus:ring-[#007AFF]/25\' \n                        : \'bg-white border-slate-200 text-neutral-900 placeholder-slate-400 focus:border-[#007AFF] focus:ring-1 focus:ring-[#007AFF]/20\'\n                    }`}\n                  />\n                </div>\n\n                <div className=\"space-y-1.5 text-left\">\n                  <label htmlFor=\"message\" className={`text-[10px] font-sans uppercase tracking-[0.15em] block font-bold ${\n                    isDark ? \'text-white/40\' : \'text-neutral-500\'\n                  }`}>\n                    System Parameters (Message) *\n                  </label>\n                  <textarea\n                    required\n                    name=\"message\"\n                    id=\"message\"\n                    rows={4}\n                    value={formData.message}\n                    onChange={handleInputChange}\n                    placeholder=\"Specify project architectures, timeline variables or corporate proposal requirements...\"\n                    className={`w-full px-4 py-3 rounded-xl text-sm border focus:outline-none transition-all duration-300 resize-none ${\n                      isDark \n                        ? \'bg-neutral-900 border-white/5 text-white placeholder-white/20 focus:border-[#007AFF] focus:ring-1 focus:ring-[#007AFF]/25\' \n                        : \'bg-white border-slate-200 text-neutral-900 placeholder-slate-400 focus:border-[#007AFF] focus:ring-1 focus:ring-[#007AFF]/20\'\n                    }`}\n                  />\n                </div>\n\n                {/* Submit button with loading triggers */}\n                <button\n                  id=\"submit-contact-button\"\n                  type=\"submit\"\n                  disabled={isSubmitting}\n                  className={`w-full py-4 px-6 rounded-2xl text-[10px] font-bold tracking-widest uppercase flex items-center justify-center gap-2 cursor-pointer transition-all duration-300 border focus:outline-none ${\n                    isSubmitting \n                      ? \'bg-neutral-800 border-neutral-700 text-slate-400 pointer-events-none\' \n                      : isDark \n                        ? \'bg-white text-black border-transparent hover:bg-[#007AFF] hover:text-white\' \n                        : \'bg-neutral-900 text-white border-transparent hover:bg-[#007AFF]\'\n                  }`}\n                >\n                  {isSubmitting ? (\n                    <>\n                      <Loader2 className=\"w-4 h-4 animate-spin\" />\n                      <span>Transmitting Blueprint Data...</span>\n                    </>\n                  ) : (\n                    <>\n                      <Send className=\"w-3.5 h-3.5\" />\n                      <span>Send Transmission</span>\n                    </>\n                  )}\n                </button>\n\n                {/* Interactive Results Screen alert */}\n                {submitResult && (\n                  <motion.div\n                    initial={{ opacity: 0, y: 10 }}\n                    animate={{ opacity: 1, y: 0 }}\n                    className={`p-4 rounded-xl text-xs flex items-start gap-2.5 border mt-4 ${\n                      submitResult.success\n                        ? \'bg-emerald-500/5 text-emerald-400 border-emerald-500/10\'\n                        : \'bg-rose-500/5 text-rose-400 border-rose-500/10\'\n                    }`}\n                  >\n                    <CheckCircle2 className=\"w-4 h-4 shrink-0 mt-0.5\" />\n                    <span>{submitResult.message}</span>\n                  </motion.div>\n                )}\n              </form>\n            </div>\n          </div>\n\n        </div>\n\n        {/* Minimal Premium Footer */}\n        <div className={`mt-24 pt-8 border-t flex flex-col md:flex-row items-center justify-between gap-4 select-none ${\n          isDark ? \'border-white/5 text-white/30\' : \'border-slate-100 text-slate-400\'\n        }`}>\n          <div className=\"text-xs font-sans font-medium\">\n            \302\251 2026 Adarsh Singh. All Systems Operational.\n          </div>\n          <div className=\"flex items-center gap-2 text-[10px] font-sans tracking-widest uppercase font-bold\">\n            <span>Crafted with precision</span>\n            <Clock className=\"w-3.5 h-3.5 text-[#007AFF] font-extrabold\" />\n          </div>\n        </div>"
      }
      num_matches: 1
    }
  }
}
