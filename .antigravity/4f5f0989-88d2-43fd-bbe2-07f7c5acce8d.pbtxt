    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport { motion } from \'motion/react\';\n\ninterface AnimatedOrbProps {\n  isDark: boolean;\n}\n\nexport default function AnimatedOrb({ isDark }: AnimatedOrbProps) {\n  return (\n    <div className=\"relative w-full aspect-square max-w-[380px] md:max-w-[450px] mx-auto flex items-center justify-center select-none\" id=\"luxury-orb-container\">\n      {/* Dynamic Ambient Background Glow */}\n      <div \n        className={`absolute inset-0 rounded-full blur-[70px] opacity-25 mix-blend-screen transition-colors duration-1000 ${\n          isDark \n            ? \'bg-gradient-to-tr from-blue-600 via-indigo-500 to-sky-400\' \n            : \'bg-gradient-to-tr from-sky-300 via-indigo-100 to-blue-200\'\n        }`}\n      />\n\n      {/* Main Breathing Orb Center */}\n      <motion.div\n        initial={{ scale: 0.8, opacity: 0 }}\n        animate={{ scale: 1, opacity: 1 }}\n        transition={{ duration: 1.5, ease: [0.16, 1, 0.3, 1] }}\n        className=\"relative z-10 w-[180px] h-[180px] md:w-[240px] md:h-[240px] rounded-full flex items-center justify-center\"\n      >\n        {/* Core sphere with metallic/liquid mirror effect */}\n        <div \n          className={`w-full h-full rounded-full transition-all duration-700 relative overflow-hidden animate-[float-slow_8s_ease-in-out_infinite] ${\n            isDark \n              ? \'bg-gradient-to-br from-neutral-800 via-slate-900 to-black border border-white/20 shadow-[inset_0_8px_32px_rgba(255,255,255,0.15)]\' \n              : \'bg-gradient-to-br from-white via-slate-100 to-neutral-200 border border-black/10 shadow-[inset_0_12px_44px_rgba(255,255,255,1),0_15px_30px_rgba(0,0,0,0.06)]\'\n          }`}\n        >\n          {/* Internal liquid highlight */}\n          <div \n            className={`absolute top-[10%] left-[15%] w-[40%] h-[40%] rounded-full blur-[8px] opacity-70 ${\n              isDark ? \'bg-gradient-to-br from-white/30 to-transparent\' : \'bg-gradient-to-br from-white/90 to-transparent\'\n            }`}\n          />\n          {/* Secondary micro light pulse */}\n          <div \n            className=\"absolute bottom-[10%] right-[10%] w-[30%] h-[30%] rounded-full blur-[14px] bg-sky-500/30 animate-[glow-pulse_5s_ease-in-out_infinite]\"\n          />\n        </div>\n\n        {/* Outer electric core outline aura */}\n        <div \n          className={`absolute inset-0 rounded-full transition-all duration-700 animate-[float-slow_8s_ease-in-out_infinite_100ms] ${\n            isDark \n              ? \'border-2 border-indigo-500/20 shadow-[0_0_30px_rgba(99,102,241,0.25)]\' \n              : \'border-2 border-slate-300/40 shadow-[0_0_20px_rgba(0,0,0,0.03)]\'\n          }`}\n        />\n      </motion.div>\n\n      {/* Luxury Rings */}\n      {/* Outer Ring 1 - Fast Tilt Ring */}\n      <motion.div\n        initial={{ rotate: -15, opacity: 0 }}\n        animate={{ rotate: 345, opacity: 1 }}\n        transition={{ repeat: Infinity, duration: 25, ease: \"linear\" }}\n        style={{ transformOrigin: \'center\' }}\n        className={`absolute w-[290px] h-[290px] md:w-[380px] md:h-[380px] rounded-full border border-dashed pointer-events-none transition-colors duration-700 ${\n          isDark ? \'border-neutral-700/60\' : \'border-neutral-300/80\'\n        }`}\n      />\n\n      {/* Internal Interactive Ring 2 - Glass Refraction */}\n      <div \n        className={`absolute w-[230px] h-[230px] md:w-[310px] md:h-[310px] rounded-full border pointer-events-none animate-[spin-reverse_35s_linear_infinite] transition-colors duration-700 ${\n          isDark \n            ? \'border-white/10 bg-white/1 backdrop-blur-[2px]\' \n            : \'border-neutral-900/10 bg-black/1 backdrop-blur-[1px]\'\n        }`}\n        style={{ transform: \'rotateX(65deg) rotateY(15deg)\' }}\n      />\n\n      {/* Inner Metallic Precision Orbit Ring 3 */}\n      <div \n        className={`absolute w-[320px] h-[320px] md:w-[410px] md:h-[410px] rounded-full border pointer-events-none animate-[spin-slow_45s_linear_infinite] transition-colors duration-700 ${\n          isDark ? \'border-sky-500/20\' : \'border-slate-400/30\'\n        }`}\n        style={{ transform: \'rotateX(45deg) rotateY(-30deg)\' }}\n      />\n\n      {/* Floating Sparkles (pure luxury geometry, no random slop) */}\n      <motion.div\n        animate={{ y: [0, -10, 0] }}\n        transition={{ repeat: Infinity, duration: 4, ease: \"easeInOut\" }}\n        className={`absolute top-[20%] left-[10%] w-2 h-2 rounded-full ${isDark ? \'bg-indigo-400/40\' : \'bg-neutral-600/40\'}`}\n      />\n      <motion.div\n        animate={{ y: [0, 8, 0] }}\n        transition={{ repeat: Infinity, duration: 5, ease: \"easeInOut\", delay: 1 }}\n        className={`absolute bottom-[25%] right-[15%] w-1.5 h-1.5 rounded-full ${isDark ? \'bg-sky-400/35\' : \'bg-slate-500/35\'}`}\n      />\n    </div>\n  );\n}\n"
