    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport { motion } from \'motion/react\';\nimport { HeroConfig } from \'../types\';\nimport AnimatedOrb from \'../components/AnimatedOrb\';\nimport { Sparkles, ArrowRight, FileText, CheckCircle2 } from \'lucide-react\';\n\ninterface HeroProps {\n  config: HeroConfig;\n  isDark: boolean;\n}\n\nexport default function Hero({ config, isDark }: HeroProps) {\n  // Stagger wrapper definitions\n  const containerVariants = {\n    hidden: { opacity: 0 },\n    visible: { \n      opacity: 1,\n      transition: { staggerChildren: 0.15, delayChildren: 0.1 }\n    }\n  };\n\n  const itemVariants = {\n    hidden: { opacity: 0, y: 30 },\n    visible: { \n      opacity: 1, \n      y: 0, \n      transition: { duration: 0.85, ease: [0.16, 1, 0.3, 1] } \n    }\n  };\n\n  return (\n    <section \n      id=\"about\" \n      className={`relative min-h-[100vh] flex items-center justify-center pt-28 pb-16 overflow-hidden ${\n        isDark \n          ? \'bg-[#050505] text-white\' \n          : \'bg-slate-50 text-neutral-900\'\n      }`}\n    >\n      {/* Absolute Cinematic Grid Pattern Background */}\n      <div \n        className={`absolute inset-0 z-0 opacity-[0.02] md:opacity-[0.035] transition-colors duration-1000 ${\n          isDark ? \'bg-[linear-gradient(rgba(255,255,255,0.06)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.06)_1px,transparent_1px)]\' : \'bg-[linear-gradient(rgba(0,0,0,0.15)_1px,transparent_1px),linear-gradient(90deg,rgba(0,0,0,0.15)_1px,transparent_1px)]\'\n        }`}\n        style={{ backgroundSize: \'45px 45px\' }}\n      />\n      \n      {/* High-Luxury Decorative Ambient Vignette */}\n      <div className=\"absolute top-1/4 left-1/4 w-[350px] h-[350px] rounded-full filter blur-[150px] opacity-10 bg-indigo-500/50 pointer-events-none\" />\n\n      <div className=\"max-w-7xl mx-auto px-6 md:px-12 relative z-10 w-full\">\n        {/* Split Hero Layout */}\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center min-h-[70vh]\">\n          \n          {/* Keynote Left Column */}\n          <motion.div \n            variants={containerVariants}\n            initial=\"hidden\"\n            animate=\"visible\"\n            className=\"lg:col-span-7 flex flex-col items-start gap-6 text-left\"\n          >\n            {/* Elite Badge Header */}\n            <motion.div \n              variants={itemVariants} \n              className={`flex items-center gap-2 px-3 py-1.5 rounded-full border text-[10px] font-semibold tracking-widest font-mono uppercase ${\n                isDark \n                  ? \'bg-neutral-900 border-neutral-800 text-sky-400\' \n                  : \'bg-white border-slate-200 text-indigo-700 shadow-sm\'\n              }`}\n            >\n              <Sparkles className=\"w-3 h-3 text-sky-400 animate-pulse\" />\n              <span>{config.badge}</span>\n            </motion.div>\n\n            {/* Massive Keynote Headline */}\n            <motion.div variants={itemVariants} className=\"space-y-2\">\n              <h1 className={`text-[3.2rem] sm:text-6xl md:text-[5.2rem] font-display font-extrabold tracking-tight leading-[1.05] ${\n                isDark\n                  ? \'text-transparent bg-clip-text bg-gradient-to-br from-white via-slate-100 to-slate-400 text-glow-blue\'\n                  : \'text-transparent bg-clip-text bg-gradient-to-br from-neutral-950 via-neutral-900 to-slate-700\'\n              }`}>\n                Building<br />\n                Intelligent Systems<br />\n                <span className={isDark ? \'text-indigo-400/95\' : \'text-indigo-600/90\'}>for the Future</span>\n              </h1>\n            </motion.div>\n\n            {/* Premium Refined Narrative Subtext */}\n            <motion.p \n              variants={itemVariants}\n              className={`text-base md:text-xl font-light leading-relaxed max-w-xl ${\n                isDark ? \'text-slate-400\' : \'text-slate-600\'\n              }`}\n            >\n              {config.subtext}\n            </motion.p>\n\n            {/* Professional Actions Row */}\n            <motion.div variants={itemVariants} className=\"flex flex-wrap items-center gap-4 mt-2\">\n              <a\n                href=\"#projects\"\n                className={`py-3.5 px-7 rounded-full text-xs font-semibold uppercase tracking-wider flex items-center gap-2 focus:outline-none transition-all duration-300 transform hover:-translate-y-0.5 cursor-pointer ${\n                  isDark \n                    ? \'bg-gradient-to-r from-blue-600 to-indigo-600 text-white hover:from-blue-500 hover:to-indigo-500 shadow-[0_10px_25px_-5px_rgba(59,130,246,0.5)]\' \n                    : \'bg-gradient-to-r from-indigo-600 to-blue-600 text-white hover:from-indigo-500 hover:to-blue-500 shadow-[0_10px_25px_-5px_rgba(79,70,229,0.3)]\'\n                }`}\n              >\n                <span>Explore Projects</span>\n                <ArrowRight className=\"w-4 h-4 transition-transform duration-300 group-hover:translate-x-1\" />\n              </a>\n\n              <a\n                href=\"mailto:adarsh2001gop@gmail.com?subject=Inquiry%20from%20Premium%20Portfolio\"\n                className={`py-3.5 px-7 rounded-full text-xs font-semibold uppercase tracking-wider flex items-center gap-2 focus:outline-none transition-all duration-300 transform hover:-translate-y-0.5 cursor-pointer ${\n                  isDark \n                    ? \'bg-neutral-900 hover:bg-neutral-800 text-white border border-white/10\' \n                    : \'bg-white hover:bg-slate-100 text-slate-800 border border-slate-300 shadow-sm\'\n                }`}\n              >\n                <FileText className=\"w-4 h-4 text-sky-400\" />\n                <span>Get In Touch</span>\n              </a>\n            </motion.div>\n\n            {/* Elegant Trust Row Certification Labels */}\n            <motion.div variants={itemVariants} className=\"mt-8 pt-8 border-t border-dashed w-full max-w-lg select-none\">\n              <span className={`text-[10px] block uppercase font-mono tracking-widest mb-3.5 font-bold ${\n                isDark ? \'text-slate-600\' : \'text-slate-400\'\n              }`}>\n                Vetted Mastery & Platforms\n              </span>\n              <div className=\"flex flex-wrap gap-x-6 gap-y-3 items-center\">\n                {config.trustRow.map((label) => (\n                  <div key={label} className=\"flex items-center gap-1.5 opacity-80 hover:opacity-100 transition-opacity duration-300\">\n                    <CheckCircle2 className=\"w-3.5 h-3.5 text-emerald-500/95\" />\n                    <span className={`text-xs font-medium font-display uppercase tracking-widest ${\n                      isDark ? \'text-slate-300\' : \'text-slate-700\'\n                    }`}>\n                      {label}\n                    </span>\n                  </div>\n                ))}\n              </div>\n            </motion.div>\n\n          </motion.div>\n          \n          {/* Keynote Right Column (Specially Custom-crafted Animated Orb Avatar) */}\n          <div className=\"lg:col-span-5 flex items-center justify-center relative w-full pt-6 lg:pt-0\">\n            <AnimatedOrb isDark={isDark} />\n          </div>\n\n        </div>\n      </div>\n    </section>\n  );\n}\n"
    }
