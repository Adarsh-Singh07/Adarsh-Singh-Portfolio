  file_change {
    absolute_path_uri: "file:///src/sections/PortfolioBento.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport { motion } from \'motion/react\';\nimport { Project, ProfileMode, Certification } from \'../types\';\nimport { \n  ArrowUpRight, \n  ExternalLink, \n  Cpu, \n  Database, \n  Award, \n  Briefcase, \n  Layers, \n  LineChart, \n  Code2 \n} from \'lucide-react\';\n\ninterface PortfolioBentoProps {\n  projects: Project[];\n  certifications: Certification[];\n  currentMode: ProfileMode;\n  isDark: boolean;\n}\n\nexport default function PortfolioBento({ projects, certifications, currentMode, isDark }: PortfolioBentoProps) {\n  // Dynamic sort of projects based on active mode priority\n  const sortedProjects = [...projects].sort((a, b) => {\n    return a.priority[currentMode] - b.priority[currentMode];\n  });\n\n  // Extract hero project dynamically\n  const heroProject = sortedProjects.find(p => p.id === \'agentic-rag-platform\') || sortedProjects[0];\n  \n  // Extract top certifications\n  const featuredCerts = certifications.filter(c => c.featured).slice(0, 5);\n\n  return (\n    <section \n      id=\"projects\" \n      className={`relative py-24 border-t transition-colors duration-1000 ${\n        isDark \n          ? \'bg-[#050505] text-white border-neutral-900\' \n          : \'bg-white text-neutral-900 border-slate-100\'\n      }`}\n    >\n      <div className=\"max-w-7xl mx-auto px-6 md:px-12 relative z-10 w-full\">\n        \n        {/* Section Header */}\n        <div className=\"mb-16 text-left max-w-3xl\">\n          <div className=\"flex items-center gap-2 mb-3\">\n            <span className={`w-8 h-[1px] ${isDark ? \'bg-sky-500\' : \'bg-indigo-600\'}`} />\n            <span className={`text-[11px] font-mono tracking-widest font-bold uppercase ${\n              isDark ? \'text-sky-400\' : \'text-indigo-600\'\n            }`}>\n              Curation & Engineering Systems\n            </span>\n          </div>\n          <h2 className=\"text-4xl md:text-5xl font-display font-extrabold tracking-tight\">\n            Featured Bento &amp; Projects\n          </h2>\n          <p className={`mt-3.5 text-base md:text-lg font-light ${\n            isDark ? \'text-slate-400\' : \'text-slate-600\'\n          }`}>\n            An asymmetrical display of critical production-grade creations, enterprise certifications, and active roles.\n          </p>\n        </div>\n\n        {/* --- PREMIUM BENTO GRID (4 Columns/Grid Areas) --- */}\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-6 mb-16 select-none\">\n          \n          {/* Card 1: HERO FEATURED PROJECT (Agentic AI + RAG Platform) */}\n          <motion.div \n            layout\n            className={`col-span-1 lg:col-span-8 p-6 md:p-8 rounded-3xl relative overflow-hidden transition-all duration-300 transform hover:-translate-y-1 hover:shadow-2xl ${\n              isDark ? \'glass-card-dark hover:border-sky-500/30\' : \'glass-card-light hover:border-indigo-600/30\'\n            }`}\n          >\n            {/* Soft decorative background asset */}\n            <div className={`absolute -right-24 -bottom-24 w-80 h-80 rounded-full filter blur-[100px] opacity-15 pointer-events-none ${\n              isDark ? \'bg-blue-500\' : \'bg-indigo-300\'\n            }`} />\n\n            <div className=\"flex flex-col h-full justify-between relative z-10\">\n              <div>\n                <div className=\"flex items-center justify-between gap-4 mb-4\">\n                  <span className={`px-2.5 py-1 rounded-full text-[9px] font-mono tracking-widest font-semibold uppercase ${\n                    isDark ? \'bg-sky-500/10 text-sky-400 border border-sky-500/20\' : \'bg-indigo-50/80 text-indigo-700 border border-indigo-200/50\'\n                  }`}>\n                    Spotlight Engineering System\n                  </span>\n                  <span className={`text-xs font-mono font-medium ${isDark ? \'text-slate-500\' : \'text-slate-400\'}`}>\n                    Active Status: <span className=\"text-emerald-500 font-semibold\">{heroProject.status}</span>\n                  </span>\n                </div>\n\n                <h3 className=\"text-2xl md:text-3xl font-display font-extrabold tracking-tight mb-3\">\n                  {heroProject.title}\n                </h3>\n                \n                <p className={`text-sm md:text-base font-light leading-relaxed mb-6 max-w-xl ${\n                  isDark ? \'text-slate-400\' : \'text-slate-600\'\n                }`}>\n                  {heroProject.description}\n                </p>\n\n                {/* Grid of technologies used in the project */}\n                <div className=\"flex flex-wrap gap-2 mb-6\">\n                  {heroProject.technologies.slice(0, 6).map((tech) => (\n                    <span \n                      key={tech} \n                      className={`px-3 py-1.5 rounded-lg text-xs font-semibold font-mono tracking-wider ${\n                        isDark ? \'bg-neutral-900 border border-neutral-800 text-slate-300\' : \'bg-slate-100 border border-slate-200 text-slate-700\'\n                      }`}\n                    >\n                      {tech}\n                    </span>\n                  ))}\n                </div>\n              </div>\n\n              {/* Integrated Live Dynamic Metrics Row */}\n              <div className=\"border-t border-dashed pt-5 mt-4 grid grid-cols-3 gap-4\">\n                {heroProject.metrics.map((metric) => (\n                  <div key={metric.label}>\n                    <span className={`text-xl md:text-2xl font-bold font-display tracking-tight block ${\n                      isDark ? \'text-sky-400\' : \'text-indigo-600\'\n                    }`}>\n                      {metric.value}\n                    </span>\n                    <span className={`text-[10px] uppercase font-mono tracking-wider ${\n                      isDark ? \'text-slate-500\' : \'text-slate-400\'\n                    }`}>\n                      {metric.label}\n                    </span>\n                  </div>\n                ))}\n              </div>\n\n              {/* View Case Study trigger */}\n              <div className=\"mt-6 flex items-center justify-end\">\n                <a \n                  href={heroProject.githubUrl}\n                  target=\"_blank\" \n                  rel=\"noreferrer\"\n                  className={`text-xs font-semibold uppercase tracking-widest flex items-center gap-1.5 transform hover:scale-102 transition-transform duration-300 ${\n                    isDark ? \'text-white\' : \'text-neutral-900\'\n                  }`}\n                >\n                  <span>Build Architecture / Case Study</span>\n                  <ArrowUpRight className=\"w-3.5 h-3.5\" />\n                </a>\n              </div>\n            </div>\n          </motion.div>\n\n          {/* Card 2: CORE EXPERTISE PANEL */}\n          <motion.div \n            layout\n            className={`col-span-1 lg:col-span-4 p-6 rounded-3xl relative overflow-hidden transition-all duration-300 transform hover:-translate-y-1 hover:shadow-2xl ${\n              isDark ? \'glass-card-dark\' : \'glass-card-light\'\n            }`}\n          >\n            <div className=\"flex flex-col h-full justify-between\">\n              <div>\n                <div className=\"flex items-center gap-2 mb-4\">\n                  <Layers className={`w-4 h-4 ${isDark ? \'text-indigo-400\' : \'text-indigo-600\'}`} />\n                  <span className={`text-[10px] uppercase font-mono tracking-widest font-bold ${\n                    isDark ? \'text-slate-500\' : \'text-slate-400\'\n                  }`}>\n                    Core Competence Maps\n                  </span>\n                </div>\n                \n                <h3 className=\"text-xl font-display font-bold tracking-tight mb-4\">\n                  Intelligent Specializations\n                </h3>\n\n                <div className=\"space-y-3\">\n                  {[\n                    \"Data Engineering\",\n                    \"Generative AI & LLMs\",\n                    \"RAG Architectures\",\n                    \"Distributed Computation\",\n                    \"Cloud Infrastructure\"\n                  ].map((expertItem, i) => (\n                    <div \n                      key={expertItem}\n                      className={`p-2.5 rounded-xl border flex items-center gap-3 transition-colors duration-300 ${\n                        isDark \n                          ? \'bg-neutral-900/60 border-neutral-800 text-slate-300 hover:bg-neutral-900\' \n                          : \'bg-slate-50 border-slate-200 text-slate-700 hover:bg-slate-100\'\n                      }`}\n                    >\n                      <div className={`w-1.5 h-1.5 rounded-full ${\n                        currentMode === \'data-engineer\' && i === 0 ? \'bg-sky-400 animate-ping\' : \'bg-emerald-400\'\n                      }`} />\n                      <span className=\"text-xs font-medium tracking-wider\">{expertItem}</span>\n                    </div>\n                  ))}\n                </div>\n              </div>\n\n              <div className={`mt-6 p-3 rounded-2xl text-[11px] font-mono leading-relaxed transition-colors duration-500 ${\n                isDark ? \'bg-slate-900/20 text-slate-400 border border-white/5\' : \'bg-slate-100/50 text-slate-500 border border-slate-200/50\'\n              }`}>\n                {currentMode === \'data-engineer\' \n                  ? \'Optimized to favor low-latency data flow throughput, Spark, and Databricks.\' \n                  : \'Staged for dynamic retrieval algorithms, OpenAI automators, and deep mathematical models.\'}\n              </div>\n            </div>\n          </motion.div>\n\n          {/* Card 3: CAPGEMINI INDUSTRY CODES */}\n          <motion.div \n            layout\n            className={`col-span-1 lg:col-span-4 p-6 rounded-3xl relative overflow-hidden transition-all duration-300 transform hover:-translate-y-1 hover:shadow-2xl ${\n              isDark ? \'glass-card-dark\' : \'glass-card-light\'\n            }`}\n          >\n            <div className=\"flex flex-col h-full justify-between\">\n              <div>\n                <div className=\"flex items-center gap-2 mb-4\">\n                  <Briefcase className={`w-4 h-4 ${isDark ? \'text-sky-400\' : \'text-indigo-600\'}`} />\n                  <span className={`text-[10px] uppercase font-mono tracking-widest font-bold ${\n                    isDark ? \'text-slate-500\' : \'text-slate-400\'\n                  }`}>\n                    Industry Placement\n                  </span>\n                </div>\n\n                <div className=\"mb-4\">\n                  <h4 className=\"text-lg font-bold font-display tracking-tight\">Capgemini</h4>\n                  <span className={`text-xs block font-mono ${isDark ? \'text-indigo-400\' : \'text-indigo-600\'}`}>\n                    Analyst \342\200\223 AI & Data Engineering\n                  </span>\n                </div>\n\n                <p className={`text-xs font-light leading-relaxed ${isDark ? \'text-slate-400\' : \'text-slate-600\'}`}>\n                  Specialized in analyzing massive structured records, optimizing cluster computations, and engineering scalable pipeline routines under clean Git automation frameworks.\n                </p>\n              </div>\n\n              <div className=\"mt-6 flex justify-between items-center bg-emerald-500/5 border border-emerald-500/10 p-3 rounded-2xl\">\n                <span className=\"text-[10px] uppercase font-mono tracking-widest text-emerald-500 font-semibold\">Active Placement</span>\n                <span className=\"text-xs font-semibold font-display\">Bengaluru, IN</span>\n              </div>\n            </div>\n          </motion.div>\n\n          {/* Card 4: CERTIFICATIONS STACK */}\n          <motion.div \n            layout\n            className={`col-span-1 lg:col-span-8 p-6 rounded-3xl relative overflow-hidden transition-all duration-300 transform hover:-translate-y-1 hover:shadow-2xl ${\n              isDark ? \'glass-card-dark\' : \'glass-card-light\'\n            }`}\n          >\n            <div className=\"flex flex-col h-full justify-between\">\n              <div>\n                <div className=\"flex items-center gap-2 mb-4\">\n                  <Award className={`w-4 h-4 ${isDark ? \'text-indigo-400\' : \'text-indigo-600\'}`} />\n                  <span className={`text-[10px] uppercase font-mono tracking-widest font-bold ${\n                    isDark ? \'text-slate-500\' : \'text-slate-400\'\n                  }`}>\n                    Industry Accreditations\n                  </span>\n                </div>\n\n                <h3 className=\"text-xl font-display font-semibold tracking-tight mb-4\">\n                  Cloud &amp; Intelligent Architecture Credentials\n                </h3>\n\n                <div className=\"grid grid-cols-1 md:grid-cols-2 gap-3\">\n                  {featuredCerts.map((cert) => (\n                    <div \n                      key={cert.id}\n                      className={`p-3 rounded-xl border flex flex-col justify-between transition-all duration-300 ${\n                        isDark \n                          ? \'bg-neutral-900 border-neutral-800 hover:border-slate-700\' \n                          : \'bg-slate-50 border-slate-200 hover:shadow-sm\'\n                      }`}\n                    >\n                      <div className=\"flex items-start justify-between gap-2\">\n                        <span className=\"text-xs font-semibold tracking-tight font-display\">{cert.title}</span>\n                      </div>\n                      <div className=\"flex items-center justify-between mt-2 pt-2 border-t border-dashed border-neutral-800\">\n                        <span className={`text-[10px] font-mono ${isDark ? \'text-slate-500\' : \'text-slate-400\'}`}>{cert.issuer}</span>\n                        <span className={`text-[10px] font-mono font-medium px-1.5 py-0.5 rounded ${\n                          isDark ? \'bg-neutral-800 text-sky-400\' : \'bg-slate-200 text-indigo-700\'\n                        }`}>\n                          {cert.date}\n                        </span>\n                      </div>\n                    </div>\n                  ))}\n                </div>\n              </div>\n            </div>\n          </motion.div>\n\n        </div>\n\n        {/* --- DETAILED HOVER PROJECTS (Product Showcase Style) --- */}\n        <div className=\"mt-20\">\n          <div className=\"flex items-center justify-between mb-8\">\n            <h3 className=\"text-2xl font-display font-extrabold tracking-tight\">\n              Featured Case Work\n            </h3>\n            <span className={`text-xs font-mono select-none ${isDark ? \'text-slate-500\' : \'text-slate-400\'}`}>\n              Dynamic Priority Ordering Active\n            </span>\n          </div>\n\n          <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n            {sortedProjects.map((proj) => (\n              <motion.div\n                key={proj.id}\n                layout\n                className={`group p-6 rounded-3xl border flex flex-col justify-between transition-all duration-500 ${\n                  isDark \n                    ? \'bg-neutral-900/40 hover:bg-neutral-900 border-neutral-900 hover:border-white/10 hover:shadow-xl\' \n                    : \'bg-white hover:bg-slate-50 border-slate-200 hover:border-slate-300 hover:shadow-lg\'\n                }`}\n              >\n                <div>\n                  <div className=\"flex items-center justify-between mb-4\">\n                    <span className={`text-[10px] uppercase font-mono tracking-widest px-2.5 py-1 rounded-full ${\n                      isDark \n                        ? proj.status === \'Deployed\' ? \'bg-emerald-500/10 text-emerald-400\' : \'bg-amber-500/10 text-amber-400\'\n                        : proj.status === \'Deployed\' ? \'bg-emerald-50 text-emerald-700\' : \'bg-amber-50 text-amber-700\'\n                    }`}>\n                      {proj.status}\n                    </span>\n                    <span className={`text-xs font-mono ${isDark ? \'text-slate-500\' : \'text-slate-400\'}`}>\n                      Priority index: #{proj.priority[currentMode]}\n                    </span>\n                  </div>\n\n                  <h4 className=\"text-xl font-bold font-display tracking-tight mb-2.5 transition-colors group-hover:text-sky-400\">\n                    {proj.title}\n                  </h4>\n\n                  <p className={`text-xs font-light leading-relaxed mb-5 ${\n                    isDark ? \'text-slate-400\' : \'text-slate-600\'\n                  }`}>\n                    {proj.description}\n                  </p>\n\n                  <div className=\"flex flex-wrap gap-1.5 mb-6\">\n                    {proj.technologies.map((t) => (\n                      <span \n                        key={t}\n                        className={`text-[10px] font-semibold font-mono tracking-wider px-2 py-0.5 rounded ${\n                          isDark ? \'bg-neutral-800 text-slate-400\' : \'bg-slate-100 text-slate-600\'\n                        }`}\n                      >\n                        {t}\n                      </span>\n                    ))}\n                  </div>\n                </div>\n\n                <div className=\"border-t border-neutral-800/10 dark:border-white/5 pt-4 flex items-center justify-between\">\n                  <div className=\"flex gap-4\">\n                    {proj.metrics.slice(0, 1).map((m) => (\n                      <div key={m.label}>\n                        <span className={`text-xs font-mono font-bold block ${isDark ? \'text-sky-400\' : \'text-indigo-600\'}`}>{m.value}</span>\n                        <span className={`text-[9px] uppercase font-mono block ${isDark ? \'text-slate-600\' : \'text-slate-400\'}`}>{m.label}</span>\n                      </div>\n                    ))}\n                  </div>\n\n                  <a\n                    href={proj.githubUrl}\n                    target=\"_blank\"\n                    rel=\"noreferrer\"\n                    className={`p-2 rounded-full cursor-pointer transition-colors ${\n                      isDark ? \'bg-neutral-800 text-white hover:bg-neutral-700\' : \'bg-slate-100 text-slate-800 hover:bg-slate-200\'\n                    }`}\n                  >\n                    <ExternalLink className=\"w-4 h-4\" />\n                  </a>\n                </div>\n              </motion.div>\n            ))}\n          </div>\n\n        </div>\n\n      </div>\n    </section>\n  );\n}\n"
