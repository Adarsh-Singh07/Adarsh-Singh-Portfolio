    replacement_chunks {
      replacement_content: "import { ProfileData } from \'../types\';\n\nexport const generalProfile: ProfileData = {\n  hero: {\n    badge: \"AI + DATA ENGINEER\",\n    titleName: \"Adarsh Singh\",\n    headline: \"Building Intelligent Systems for the Future\",\n    subtext: \"AI & Data Engineer specialized in crafting scalable systems using Generative AI, RAG, ETL pipelines, and low-latency cloud infrastructure.\",\n    trustRow: [\"Capgemini\", \"Azure\", \"AWS\", \"GCP\", \"RAG\", \"LLMs\", \"Docker\", \"Python\"]\n  },\n  projects: [\n    {\n      id: \"agentic-rag-platform\",\n      title: \"Agentic AI + RAG Platform\",\n      description: \"An enterprise-grade hybrid Agentic AI & Retrieval-Augmented Generation ecosystem enabling dynamic workflows, real-time citation analysis, and multi-agent systems orchestration.\",\n      technologies: [\"Docker\", \"REST APIs\", \"WebSockets\", \"RAG\", \"Agentic AI\", \"Microservices\", \"Python\"],\n      metrics: [\n        { label: \"Projected Cost Uplift\", value: \"18%\" },\n        { label: \"Customer Support Resolution\", value: \"60% Faster\" },\n        { label: \"Token Processing Latency\", value: \"<140ms\" }\n      ],\n      githubUrl: \"https://github.com/Adarsh-Singh07\",\n      demoUrl: \"https://github.com/Adarsh-Singh07\",\n      status: \"Beta\",\n      featured: true,\n      priority: {\n        general: 1,\n        \'data-engineer\': 2\n      }\n    },\n    {\n      id: \"indian-sign-language-translator\",\n      title: \"Indian Sign Language ML Translation\",\n      description: \"An end-to-end computer vision and deep learning application translating real-time Indian Sign Language gestures into fluid text & natural speech pipelines, deploying lightweight model endpoints.\",\n      technologies: [\"PyTorch\", \"OpenCV\", \"FastAPI\", \"TensorFlow\", \"React\", \"Docker\"],\n      metrics: [\n        { label: \"Model Interface Accuracy\", value: \"98.2%\" },\n        { label: \"Gesture Latency Response\", value: \"~45ms\" }\n      ],\n      githubUrl: \"https://github.com/Adarsh-Singh07\",\n      status: \"Deployed\",\n      featured: true,\n      priority: {\n        general: 2,\n        \'data-engineer\': 3\n      }\n    },\n    {\n      id: \"email-campaign-automation\",\n      title: \"Email Campaign Automation with OpenAI\",\n      description: \"A highly intelligent, self-optimizing outbound and feedback workflow managing lead generation pipelines, using fine-tuned OpenAI LLM engines and customized vector stores.\",\n      technologies: [\"OpenAI LLM\", \"Python\", \"Vector Stores\", \"Celery\", \"Redis\", \"Azure\"],\n      metrics: [\n        { label: \"Cold Outreach Engagement\", value: \"+40%\" },\n        { label: \"Lead Response Rate\", value: \"3.2x Scale\" }\n      ],\n      githubUrl: \"https://github.com/Adarsh-Singh07\",\n      status: \"Deployed\",\n      featured: true,\n      priority: {\n        general: 3,\n        \'data-engineer\': 4\n      }\n    },\n    {\n      id: \"scalable-etl-data-lakehouse\",\n      title: \"Next-Gen Scalable ETL & Data Lakehouse\",\n      description: \"High-performance distributed data lakehouse ingest engine processing telemetry records, applying structured medallion transformations, and supporting ultra-low latency SQL analytical queries.\",\n      technologies: [\"Databricks\", \"Apache Spark\", \"Delta Lake\", \"Azure ADF\", \"SQL\", \"BigQuery\"],\n      metrics: [\n        { label: \"Daily Transmitted Logs\", value: \"120M+\" },\n        { label: \"Pipeline Computation Savings\", value: \"35%\" },\n        { label: \"Analytical Query Latency\", value: \"Sub-second\" }\n      ],\n      githubUrl: \"https://github.com/Adarsh-Singh07\",\n      status: \"Beta\",\n      featured: true,\n      priority: {\n        general: 4,\n        \'data-engineer\': 1\n      }\n    }\n  ],\n  skills: [\n    {\n      title: \"Generative AI\",\n      skills: [\n        { name: \"LLMs (GPT-4, Gemini, Claude)\", level: \"Expert\" },\n        { name: \"Retrieval-Augmented Gen (RAG)\", level: \"Expert\" },\n        { name: \"Agentic AI Frameworks\", level: \"Expert\" },\n        { name: \"Transformers & Attention Nets\", level: \"Advanced\" },\n        { name: \"NLP & Semantic Search\", level: \"Expert\" },\n        { name: \"PyTorch & TensorFlow\", level: \"Advanced\" }\n      ],\n      priority: {\n        general: 1,\n        \'data-engineer\': 2\n      }\n    },\n    {\n      title: \"Data Engineering\",\n      skills: [\n        { name: \"ETL & Medallion Pipeline Design\", level: \"Expert\" },\n        { name: \"Deep SQL Optimization\", level: \"Expert\" },\n        { name: \"Databricks & Delta Lakes\", level: \"Advanced\" },\n        { name: \"Distributed Data Processing\", level: \"Advanced\" },\n        { name: \"Data Warehousing & Modeling\", level: \"Expert\" }\n      ],\n      priority: {\n        general: 2,\n        \'data-engineer\': 1\n      }\n    },\n    {\n      title: \"Cloud & Infrastructure\",\n      skills: [\n        { name: \"Azure (Synapse, ADF, VMs)\", level: \"Expert\" },\n        { name: \"GCP (BigQuery, Vertex AI)\", level: \"Advanced\" },\n        { name: \"Docker Containerization\", level: \"Expert\" },\n        { name: \"Microservices & REST APIs\", level: \"Expert\" },\n        { name: \"Kubernetes & Orchestration\", level: \"Intermediate\" }\n      ],\n      priority: {\n        general: 3,\n        \'data-engineer\': 3\n      }\n    },\n    {\n      title: \"Backend Core\",\n      skills: [\n        { name: \"Advanced Python\", level: \"Expert\" },\n        { name: \"FastAPI, Flask, Django\", level: \"Expert\" },\n        { name: \"CI/CD & Git/GitHub Actions\", level: \"Advanced\" },\n        { name: \"Distributed Async Tasks (Celery)\", level: \"Advanced\" }\n      ],\n      priority: {\n        general: 4,\n        \'data-engineer\': 4\n      }\n    },\n    {\n      title: \"Visualization & Insights\",\n      skills: [\n        { name: \"Power BI Premium\", level: \"Expert\" },\n        { name: \"Tableau Enterprise\", level: \"Advanced\" },\n        { name: \"Looker Studio & custom charts\", level: \"Advanced\" },\n        { name: \"Matplotlib & Seaborn plots\", level: \"Expert\" }\n      ],\n      priority: {\n        general: 5,\n        \'data-engineer\': 5\n      }\n    }\n  ],\n  certifications: [\n    {\n      id: \"ai-102\",\n      title: \"AI-102: Designing and Implementing an Azure AI Solution\",\n      issuer: \"Microsoft Certified\",\n      code: \"AI-102\",\n      date: \"2025\",\n      badgeUrl: \"https://learn.microsoft.com\",\n      featured: true,\n      priority: {\n        general: 1,\n        \'data-engineer\': 3\n      }\n    },\n    {\n      id: \"aws-ai-practitioner\",\n      title: \"AWS Certified AI Practitioner\",\n      issuer: \"Amazon Web Services\",\n      code: \"AWSE-AI\",\n      date: \"2025\",\n      badgeUrl: \"https://aws.amazon.com\",\n      featured: true,\n      priority: {\n        general: 2,\n        \'data-engineer\': 4\n      }\n    },\n    {\n      id: \"google-genai-leader\",\n      title: \"Google Cloud Generative AI Leader\",\n      issuer: \"Google Cloud\",\n      date: \"2025\",\n      featured: true,\n      priority: {\n        general: 3,\n        \'data-engineer\': 5\n      }\n    },\n    {\n      id: \"azure-cloud-developer\",\n      title: \"Professional Cloud Developer Associate\",\n      issuer: \"Microsoft Certified\",\n      code: \"AZ-204\",\n      date: \"2024\",\n      featured: true,\n      priority: {\n        general: 4,\n        \'data-engineer\': 2\n      }\n    },\n    {\n      id: \"az-900\",\n      title: \"AZ-900: Microsoft Azure Fundamentals\",\n      issuer: \"Microsoft Certified\",\n      code: \"AZ-900\",\n      date: \"2024\",\n      featured: false,\n      priority: {\n        general: 5,\n        \'data-engineer\': 6\n      }\n    },\n    {\n      id: \"ai-900\",\n      title: \"AI-900: Azure AI Fundamentals\",\n      issuer: \"Microsoft Certified\",\n      code: \"AI-900\",\n      date: \"2024\",\n      featured: false,\n      priority: {\n        general: 6,\n        \'data-engineer\': 7\n      }\n    }\n  ],\n  journey: [\n    {\n      id: \"jm-1\",\n      era: \"Foundation\",\n      title: \"Mathematics & Computer Science Focus\",\n      subtitle: \"Academic Underpinnings\",\n      description: \"Forged a deep understanding of logical calculation, relational databases, data structures, and computational optimization.\",\n      period: \"2020 - 2023\",\n      emphasis: {\n        general: true,\n        \'data-engineer\': true\n      }\n    },\n    {\n      id: \"jm-2\",\n      era: \"Transformation\",\n      title: \"Post-Graduate Focus (MCA)\",\n      subtitle: \"AI, ML, & Data Specialization\",\n      description: \"Advanced thesis and lab work focusing on deep neural networks, distributed systems architecture, and transactional workloads.\",\n      period: \"2023 - 2025\",\n      emphasis: {\n        general: true,\n        \'data-engineer\': true\n      }\n    },\n    {\n      id: \"jm-3\",\n      era: \"Industry Experience\",\n      title: \"Capgemini\",\n      subtitle: \"Analyst \342\200\223 AI & Data Engineering\",\n      description: \"Designing end-to-end cloud ETL processes, managing scalable Azure resources, optimizing query metrics, and deploying deep learning translation APIs.\",\n      period: \"Present Era\",\n      emphasis: {\n        general: true,\n        \'data-engineer\': true\n      }\n    },\n    {\n      id: \"jm-4\",\n      era: \"Builder Era\",\n      title: \"Architecting Agentic RAG\",\n      subtitle: \"Pioneering Automation Solutions\",\n      description: \"Created customized RAG architectures, Indian Sign Language visual models, and self-improving email automation modules utilizing LLMs.\",\n      period: \"Continuous\",\n      emphasis: {\n        general: true,\n        \'data-engineer\': true\n      }\n    }\n  ],\n  blogs: [\n    {\n      id: \"blog-rag-arch\",\n      title: \"Understanding RAG Architectures: From Vector Databases to HyDE\",\n      excerpt: \"A deep structural dive into modern RAG pipelines, highlighting hybrid indexing, semantic search, and Hypothetical Document Embeddings for minimal latency.\",\n      readTime: \"6 min read\",\n      category: \"GenAI & RAG\",\n      date: \"May 2026\",\n      url: \"#\",\n      priority: {\n        general: 1,\n        \'data-engineer\': 3\n      }\n    },\n    {\n      id: \"blog-etl-spark\",\n      title: \"Building Scalable ETL Pipelines with Spark & Azure\",\n      excerpt: \"Best practices in architecting resilient, transactionally secure medallion data flows using Azure Data Factory, Databricks, and Optimized Delta Tables.\",\n      readTime: \"8 min read\",\n      category: \"Data Engineering\",\n      date: \"April 2026\",\n      url: \"#\",\n      priority: {\n        general: 2,\n        \'data-engineer\': 1\n      }\n    },\n    {\n      id: \"blog-de-matters\",\n      title: \"Why Data Engineering is the Core Pillar of Pragmatic AI\",\n      excerpt: \"Explaining the infrastructure reality: before you can fine-tune or train an LLM/Agent, your raw distributed ledger data lakes must be pure, clean, and real-time.\",\n      readTime: \"5 min read\",\n      category: \"Infrastructure\",\n      date: \"Feb 2026\",\n      url: \"#\",\n      priority: {\n        general: 3,\n        \'data-engineer\': 2\n      }\n    },\n    {\n      id: \"blog-agentic-systems\",\n      title: \"Lessons Build-Tested in Multi-Agent Autonomous Workflows\",\n      excerpt: \"Practical architectural patterns for stateful multi-agent systems, dealing with loop handling, self-correction traps, and token spend controls.\",\n      readTime: \"7 min read\",\n      category: \"Agentic AI\",\n      date: \"Jan 2026\",\n      url: \"#\",\n      priority: {\n        general: 4,\n        \'data-engineer\': 4\n      }\n    }\n  ],\n  philosophy: \"I believe intelligent systems should scale elegantly, solve meaningful problems, and create real impact.\"\n};\n\n// Data Engineer-optimized override (can have strategic title tuning, different metrics emphasis etc.)\nexport const dataEngineerProfile: ProfileData = {\n  ...generalProfile,\n  hero: {\n    badge: \"SENIOR DATA ENGINE DEV\",\n    titleName: \"Adarsh Singh\",\n    headline: \"Architecting Elite Enterprise Data Ecosystems\",\n    subtext: \"AI-forward Data Engineer specializing in distributed computation lakes, optimized medallion ETL pipelines, Azure/GCP data operations, and secure RAG infrastructure.\",\n    trustRow: [\"Capgemini\", \"Apache Spark\", \"Databricks\", \"Azure ADF\", \"Delta Lake\", \"BigQuery\", \"SQL\", \"Docker\"]\n  }\n};\n"
    }
