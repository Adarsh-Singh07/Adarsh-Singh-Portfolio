      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport { motion } from \'motion/react\';\nimport { JourneyMilestone, BlogNote, ProfileMode } from \'../types\';\nimport { BookOpen, Compass, Target, ArrowUpRight, GraduationCap } from \'lucide-react\';\n\ninterface JourneySectionProps {\n  journey: JourneyMilestone[];\n  blogs: BlogNote[];\n  currentMode: ProfileMode;\n  philosophy: string;\n  isDark: boolean;\n}\n\nexport default function JourneySection({ journey, blogs, currentMode, philosophy, isDark }: JourneySectionProps) {\n  // Sort blogs based on current mode priority\n  const sortedBlogs = [...blogs].sort((a, b) => {\n    return a.priority[currentMode] - b.priority[currentMode];\n  });\n\n  return (\n    <section \n      id=\"journey\" \n      className={`relative py-24 transition-colors duration-1000 ${\n        isDark \n          ? \'bg-[#050505] text-white\' \n          : \'bg-white text-neutral-900\'\n      }`}\n    >\n      <div className=\"max-w-7xl mx-auto px-6 md:px-12 relative z-10 w-full\">\n        \n        {/* Step 4 Section Title */}\n        <div className=\"mb-16 text-left max-w-3xl\">\n          <div className=\"flex items-center gap-2 mb-3\">\n            <span className={`w-8 h-[1px] ${isDark ? \'bg-indigo-400\' : \'bg-indigo-600\'}`} />\n            <span className={`text-[11px] font-mono tracking-widest font-bold uppercase ${\n              isDark ? \'text-indigo-400\' : \'text-indigo-600\'\n            }`}>\n              Origin Story & Continuous Growth\n            </span>\n          </div>\n          <h2 className=\"text-4xl md:text-5xl font-display font-extrabold tracking-tight\">\n            The Journey\n          </h2>\n          <p className={`mt-3.5 text-base md:text-lg font-light ${\n            isDark ? \'text-slate-400\' : \'text-slate-600\'\n          }`}>\n            Tracing progress from logical computing mathematics to crafting massive real-time pipelines and learning systems.\n          </p>\n        </div>\n\n        {/* --- HORIZONTAL SCROLL STORYTELLING TIMELINE --- */}\n        <div className=\"mb-24 overflow-x-auto pb-8 pt-4 scrollbar-thin select-none\" id=\"journey-timeline-scroller\">\n          <div className=\"flex gap-6 min-w-[1000px] md:min-w-[1200px] px-2 relative\">\n            \n            {/* Draw Horizontal Connecting Line */}\n            <div className={`absolute top-1/2 left-0 right-0 h-[2px] z-0 -translate-y-1/2 ${\n              isDark ? \'bg-gradient-to-r from-blue-900/40 via-indigo-800/40 to-neutral-900\' : \'bg-gradient-to-r from-slate-200 via-indigo-100 to-slate-200\'\n            }`} />\n\n            {journey.map((item, index) => {\n              const isEmphasized = item.emphasis[currentMode];\n              \n              return (\n                <motion.div\n                  key={item.id}\n                  layoutId={item.id}\n                  className={`w-[260px] md:w-[320px] p-6 rounded-2xl relative z-10 border transition-all duration-500 flex flex-col justify-between ${\n                    isEmphasized\n                      ? isDark \n                        ? \'bg-neutral-900 border-indigo-500/30 shadow-[0_10px_25px_-5px_rgba(99,102,241,0.2)]\' \n                        : \'bg-white border-indigo-200 shadow-[0_10px_25px_-5px_rgba(79,70,229,0.06)]\'\n                      : isDark\n                        ? \'bg-neutral-950/80 border-neutral-900/80 hover:border-neutral-800\'\n                        : \'bg-slate-50/80 border-slate-200/80 hover:border-slate-300\'\n                  }`}\n                >\n                  <div>\n                    {/* Floating Step Badge */}\n                    <div className=\"flex items-center justify-between gap-2 mb-4\">\n                      <span className={`text-[10px] font-mono tracking-widest font-semibold uppercase ${\n                        isDark ? \'text-sky-400\' : \'text-indigo-700\'\n                      }`}>\n                        {item.era}\n                      </span>\n                      <span className={`text-[10px] font-mono font-medium ${isDark ? \'text-slate-600\' : \'text-slate-400\'}`}>\n                        {item.period}\n                      </span>\n                    </div>\n\n                    <h4 className=\"text-base font-bold font-display tracking-tight leading-snug mb-1\">\n                      {item.title}\n                    </h4>\n                    \n                    <span className={`text-xs block font-display tracking-wide mb-3 ${\n                      isDark ? \'text-slate-400\' : \'text-slate-500\'\n                    }`}>\n                      {item.subtitle}\n                    </span>\n\n                    <p className={`text-xs font-light leading-relaxed ${\n                      isDark ? \'text-slate-400/90\' : \'text-slate-650\'\n                    }`}>\n                      {item.description}\n                    </p>\n                  </div>\n\n                  <div className=\"mt-5 pt-3 border-t border-dashed border-neutral-800/20 dark:border-white/5 flex items-center justify-between\">\n                    <span className=\"text-[9px] uppercase font-mono text-slate-500\">Timeline Milestone 0{index + 1}</span>\n                    {isEmphasized && (\n                      <div className=\"w-2 h-2 rounded-full bg-emerald-500 animate-pulse\" />\n                    )}\n                  </div>\n                </motion.div>\n              );\n            })}\n\n            {/* Extra Future Vision card block */}\n            <div className={`w-[260px] md:w-[320px] p-6 rounded-2xl border flex flex-col justify-between ${\n              isDark ? \'bg-neutral-950 border-neutral-900/60\' : \'bg-slate-50 border-slate-200/80\'\n            }`}>\n              <div>\n                <div className=\"flex items-center justify-between gap-2 mb-4\">\n                  <span className={`text-[10px] font-mono tracking-widest font-semibold uppercase ${\n                    isDark ? \'text-indigo-400\' : \'text-indigo-700\'\n                  }`}>\n                    Vision\n                  </span>\n                  <Target className=\"w-3.5 h-3.5 text-indigo-500\" />\n                </div>\n                <h4 className=\"text-base font-bold font-display tracking-tight leading-snug mb-2\">\n                  Future Continuous\n                </h4>\n                <p className={`text-xs font-light leading-relaxed ${\n                  isDark ? \'text-slate-400\' : \'text-slate-600\'\n                }`}>\n                  \342\200\234Building intelligent infrastructure for the future of AI systems.\342\200\235\n                </p>\n              </div>\n              <div className=\"mt-5 pt-3 border-t border-dashed border-neutral-800/10 dark:border-white/5 flex items-center justify-between text-[9px] uppercase font-mono text-slate-500\">\n                <span>Milestone 05</span>\n                <span>Active</span>\n              </div>\n            </div>\n\n          </div>\n        </div>\n\n        {/* --- DYNAMIC BLOG ARTICLES (Apple News / Medium Premium editorial look) --- */}\n        <div className=\"mt-28\" id=\"blogs\">\n          <div className=\"flex flex-col md:flex-row md:items-end justify-between mb-12\">\n            <div>\n              <div className=\"flex items-center gap-2 mb-3\">\n                <BookOpen className={`w-4 h-4 ${isDark ? \'text-sky-400\' : \'text-indigo-600\'}`} />\n                <h3 className=\"text-2xl font-display font-bold tracking-tight\">Thoughts &amp; Engineering Notes</h3>\n              </div>\n              <p className={`text-sm font-light ${isDark ? \'text-slate-500\' : \'text-slate-600\'}`}>\n                Scribbles, architectural breakdowns, and learnings from deploying code pipelines.\n              </p>\n            </div>\n            <span className={`text-[11px] font-mono tracking-widest block mt-4 md:mt-0 font-medium ${\n              isDark ? \'text-slate-600\' : \'text-slate-400\'\n            }`}>\n              {currentMode === \'data-engineer\' ? \'RECOMMENDING DATA PAPERS FIRST\' : \'RECOMMENDING RAG THEORIES FIRST\'}\n            </span>\n          </div>\n\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-8\">\n            {sortedBlogs.map((post) => (\n              <motion.article \n                key={post.id}\n                layout\n                className={`p-6 md:p-8 rounded-3xl border flex flex-col justify-between transition-all duration-400 hover:shadow-xl ${\n                  isDark \n                    ? \'bg-neutral-900 border-neutral-900 hover:border-slate-800\' \n                    : \'bg-white border-slate-200/80 hover:border-slate-300\'\n                }`}\n              >\n                <div>\n                  <div className=\"flex items-center justify-between mb-4\">\n                    <span className={`text-[10px] uppercase font-mono tracking-widest font-semibold px-2.5 py-1 rounded-full ${\n                      isDark ? \'bg-neutral-950 text-slate-400\' : \'bg-slate-100 text-slate-600\'\n                    }`}>\n                      {post.category}\n                    </span>\n                    <span className={`text-[10px] font-mono ${isDark ? \'text-slate-600\' : \'text-slate-400\'}`}>\n                      {post.readTime}\n                    </span>\n                  </div>\n\n                  <h4 className=\"text-lg md:text-xl font-bold font-display tracking-tight mb-3 hover:text-indigo-500 transition-colors\">\n                    <a href={post.url}>{post.title}</a>\n                  </h4>\n\n                  <p className={`text-xs md:text-sm font-light leading-relaxed mb-6 ${\n                    isDark ? \'text-slate-400\' : \'text-slate-600\'\n                  }`}>\n                    {post.excerpt}\n                  </p>\n                </div>\n\n                <div className=\"border-t border-dashed border-neutral-800/10 dark:border-white/5 pt-4 flex items-center justify-between\">\n                  <span className={`text-[10px] font-mono ${isDark ? \'text-slate-600\' : \'text-slate-400\'}`}>\n                    Published {post.date}\n                  </span>\n                  <a \n                    href={post.url}\n                    className={`text-xs font-semibold uppercase tracking-widest flex items-center gap-1.5 transition-colors ${\n                      isDark ? \'text-slate-300 hover:text-sky-400\' : \'text-slate-700 hover:text-indigo-650\'\n                    }`}\n                  >\n                    <span>Read Article</span>\n                    <ArrowUpRight className=\"w-3.5 h-3.5\" />\n                  </a>\n                </div>\n              </motion.article>\n            ))}\n          </div>\n        </div>\n\n        {/* --- LUXURY CINEMATIC QUOTE OR PHILOSOPHY WORDING --- */}\n        <div className=\"mt-32 pt-16 border-t border-dashed border-neutral-800/20 dark:border-white/5 text-center\">\n          <div className=\"max-w-3xl mx-auto px-4 select-none\">\n            <span className={`text-[9px] uppercase font-mono tracking-widest block mb-4 font-bold ${\n              isDark ? \'text-indigo-400\' : \'text-indigo-600\'\n            }`}>\n              Personal Creed\n            </span>\n            <blockquote className={`text-xl md:text-3xl font-display font-light italic leading-relaxed tracking-wide ${\n              isDark ? \'text-slate-200\' : \'text-neutral-900 font-normal\'\n            }`}>\n              \342\200\234{philosophy}\342\200\235\n            </blockquote>\n            <div className={`mt-4 text-xs font-mono tracking-widest uppercase ${\n              isDark ? \'text-slate-500\' : \'text-slate-400\'\n            }`}>\n              \342\200\224 Adarsh Singh\n            </div>\n          </div>\n        </div>\n\n      </div>\n    </section>\n  );\n}\n"
    }
