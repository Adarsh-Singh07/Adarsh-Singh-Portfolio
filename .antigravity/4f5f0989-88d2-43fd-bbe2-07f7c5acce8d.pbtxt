    replacement_infos {
      original_chunk {
        target_content: "        {/* Step 4 Section Title */}\n        <div className=\"mb-16 text-left max-w-3xl\">\n          <div className=\"flex items-center gap-2 mb-3\">\n            <span className={`w-8 h-[1px] ${isDark ? \'bg-indigo-400\' : \'bg-indigo-600\'}`} />\n            <span className={`text-[11px] font-mono tracking-widest font-bold uppercase ${\n              isDark ? \'text-indigo-400\' : \'text-indigo-600\'\n            }`}>\n              Origin Story & Continuous Growth\n            </span>\n          </div>\n          <h2 className=\"text-4xl md:text-5xl font-display font-extrabold tracking-tight\">\n            The Journey\n          </h2>\n          <p className={`mt-3.5 text-base md:text-lg font-light ${\n            isDark ? \'text-slate-400\' : \'text-slate-600\'\n          }`}>\n            Tracing progress from logical computing mathematics to crafting massive real-time pipelines and learning systems.\n          </p>\n        </div>\n\n        {/* --- HORIZONTAL SCROLL STORYTELLING TIMELINE --- */}\n        <div className=\"mb-24 overflow-x-auto pb-8 pt-4 scrollbar-thin select-none\" id=\"journey-timeline-scroller\">\n          <div className=\"flex gap-6 min-w-[1000px] md:min-w-[1200px] px-2 relative\">\n            \n            {/* Draw Horizontal Connecting Line */}\n            <div className={`absolute top-1/2 left-0 right-0 h-[2px] z-0 -translate-y-1/2 ${\n              isDark ? \'bg-gradient-to-r from-blue-900/40 via-indigo-800/40 to-neutral-900\' : \'bg-gradient-to-r from-slate-200 via-indigo-100 to-slate-200\'\n            }`} />\n\n            {journey.map((item, index) => {\n              const isEmphasized = item.emphasis[currentMode];\n              \n              return (\n                <motion.div\n                  key={item.id}\n                  layoutId={item.id}\n                  className={`w-[260px] md:w-[320px] p-6 rounded-2xl relative z-10 border transition-all duration-500 flex flex-col justify-between ${\n                    isEmphasized\n                      ? isDark \n                        ? \'bg-neutral-900 border-indigo-500/30 shadow-[0_10px_25px_-5px_rgba(99,102,241,0.2)]\' \n                        : \'bg-white border-indigo-200 shadow-[0_10px_25px_-5px_rgba(79,70,229,0.06)]\'\n                      : isDark\n                        ? \'bg-neutral-950/80 border-neutral-900/80 hover:border-neutral-800\'\n                        : \'bg-slate-50/80 border-slate-200/80 hover:border-slate-300\'\n                  }`}\n                >\n                  <div>\n                    {/* Floating Step Badge */}\n                    <div className=\"flex items-center justify-between gap-2 mb-4\">\n                      <span className={`text-[10px] font-mono tracking-widest font-semibold uppercase ${\n                        isDark ? \'text-sky-400\' : \'text-indigo-700\'\n                      }`}>\n                        {item.era}\n                      </span>\n                      <span className={`text-[10px] font-mono font-medium ${isDark ? \'text-slate-600\' : \'text-slate-400\'}`}>\n                        {item.period}\n                      </span>\n                    </div>\n\n                    <h4 className=\"text-base font-bold font-display tracking-tight leading-snug mb-1\">\n                      {item.title}\n                    </h4>\n                    \n                    <span className={`text-xs block font-display tracking-wide mb-3 ${\n                      isDark ? \'text-slate-400\' : \'text-slate-500\'\n                    }`}>\n                      {item.subtitle}\n                    </span>\n\n                    <p className={`text-xs font-light leading-relaxed ${\n                      isDark ? \'text-slate-400/90\' : \'text-slate-650\'\n                    }`}>\n                      {item.description}\n                    </p>\n                  </div>\n\n                  <div className=\"mt-5 pt-3 border-t border-dashed border-neutral-800/20 dark:border-white/5 flex items-center justify-between\">\n                    <span className=\"text-[9px] uppercase font-mono text-slate-500\">Timeline Milestone 0{index + 1}</span>\n                    {isEmphasized && (\n                      <div className=\"w-2 h-2 rounded-full bg-emerald-500 animate-pulse\" />\n                    )}\n                  </div>\n                </motion.div>\n              );\n            })}"
        replacement_content: "        {/* Step 4 Section Title */}\n        <div className=\"mb-16 text-left max-w-3xl\">\n          <div className=\"flex items-center gap-2 mb-3\">\n            <span className=\"w-8 h-[1px] bg-[#007AFF]\" />\n            <span className=\"text-[10px] font-bold uppercase tracking-[0.2em] text-[#007AFF]\">\n              Origin Story & Continuous Growth\n            </span>\n          </div>\n          <h2 className=\"text-4xl md:text-5xl font-sans font-semibold tracking-tight\">\n            The Journey\n          </h2>\n          <p className={`mt-3.5 text-base md:text-lg font-light ${\n            isDark ? \'text-white/50\' : \'text-neutral-950/60\'\n          }`}>\n            Tracing progress from logical computing mathematics to crafting massive real-time pipelines and learning systems.\n          </p>\n        </div>\n\n        {/* --- HORIZONTAL SCROLL STORYTELLING TIMELINE --- */}\n        <div className=\"mb-24 overflow-x-auto pb-8 pt-4 scrollbar-thin select-none\" id=\"journey-timeline-scroller\">\n          <div className=\"flex gap-6 min-w-[1000px] md:min-w-[1200px] px-2 relative\">\n            \n            {/* Draw Horizontal Connecting Line */}\n            <div className={`absolute top-1/2 left-0 right-0 h-[2px] z-0 -translate-y-1/2 ${\n              isDark ? \'bg-gradient-to-r from-[#007AFF]/10 via-[#007AFF]/30 to-transparent\' : \'bg-gradient-to-r from-slate-200 via-slate-350 to-slate-200\'\n            }`} />\n\n            {journey.map((item, index) => {\n              const isEmphasized = item.emphasis[currentMode];\n              \n              return (\n                <motion.div\n                  key={item.id}\n                  layoutId={item.id}\n                  className={`w-[260px] md:w-[320px] p-6 rounded-[28px] relative z-10 border transition-all duration-500 flex flex-col justify-between ${\n                    isEmphasized\n                      ? isDark \n                        ? \'bg-[#151515] border-[#007AFF]/35 shadow-[0_15px_30px_rgba(0,122,255,0.15)]\' \n                        : \'bg-white border-[#007AFF]/30 shadow-[0_10px_25px_-5px_rgba(0,122,255,0.06)]\'\n                      : isDark\n                        ? \'bg-[#121212]/90 border-white/5 hover:border-white/10\'\n                        : \'bg-slate-50/80 border-slate-200/80 hover:border-slate-300\'\n                  }`}\n                >\n                  <div>\n                    {/* Floating Step Badge */}\n                    <div className=\"flex items-center justify-between gap-2 mb-4\">\n                      <span className=\"text-[10px] font-serif italic font-bold text-[#007AFF]\">\n                        {item.era}\n                      </span>\n                      <span className={`text-[10px] font-sans font-bold tracking-wider ${isDark ? \'text-white/30\' : \'text-neutral-400\'}`}>\n                        {item.period}\n                      </span>\n                    </div>\n\n                    <h4 className=\"text-base font-semibold font-sans tracking-tight leading-snug mb-1\">\n                      {item.title}\n                    </h4>\n                    \n                    <span className={`text-xs block font-serif italic mb-3 ${\n                      isDark ? \'text-white/50\' : \'text-neutral-500\'\n                    }`}>\n                      {item.subtitle}\n                    </span>\n\n                    <p className={`text-xs font-light leading-relaxed ${\n                      isDark ? \'text-white/50\' : \'text-neutral-950/60\'\n                    }`}>\n                      {item.description}\n                    </p>\n                  </div>\n\n                  <div className=\"mt-5 pt-3 border-t border-dashed border-white/5 flex items-center justify-between\">\n                    <span className={`text-[9px] uppercase font-sans tracking-widest font-bold ${isDark ? \'text-white/30\' : \'text-neutral-400\'}`}>Timeline Milestone 0{index + 1}</span>\n                    {isEmphasized && (\n                      <div className=\"w-2 h-2 rounded-full bg-emerald-500 animate-pulse\" />\n                    )}\n                  </div>\n                </motion.div>\n              );\n            })}"
      }
      num_matches: 1
    }
  }
