  file_change {
    absolute_path_uri: "file:///src/sections/SkillsSection.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport { motion } from \'motion/react\';\nimport { SkillCategory, Certification, ProfileMode } from \'../types\';\nimport { Cpu, Terminal, ShieldAlert, Award, Compass, Sparkles } from \'lucide-react\';\n\ninterface SkillsSectionProps {\n  categories: SkillCategory[];\n  certifications: Certification[];\n  currentMode: ProfileMode;\n  isDark: boolean;\n}\n\nexport default function SkillsSection({ categories, certifications, currentMode, isDark }: SkillsSectionProps) {\n  // Sort category priority based on dynamic mode priority\n  const sortedCategories = [...categories].sort((a, b) => {\n    return a.priority[currentMode] - b.priority[currentMode];\n  });\n\n  // Sort certifications\n  const sortedCerts = [...certifications].sort((a, b) => {\n    return a.priority[currentMode] - b.priority[currentMode];\n  });\n\n  return (\n    <section \n      id=\"skills\" \n      className={`relative py-24 transition-colors duration-1000 ${\n        isDark \n          ? \'bg-[#050505] text-white\' \n          : \'bg-slate-50 text-neutral-900\'\n      }`}\n    >\n      <div className=\"absolute inset-0 z-0 opacity-10 pointer-events-none\" />\n\n      <div className=\"max-w-7xl mx-auto px-6 md:px-12 relative z-10 w-full\">\n        \n        {/* Step 3 Section Title */}\n        <div className=\"mb-16 text-left max-w-3xl\">\n          <div className=\"flex items-center gap-2 mb-3\">\n            <span className={`w-8 h-[1px] ${isDark ? \'bg-indigo-400\' : \'bg-indigo-600\'}`} />\n            <span className={`text-[11px] font-mono tracking-widest font-bold uppercase ${\n              isDark ? \'text-indigo-400\' : \'text-indigo-600\'\n            }`}>\n              Capabilities & Verified Standards\n            </span>\n          </div>\n          <h2 className=\"text-4xl md:text-5xl font-display font-extrabold tracking-tight\">\n            Engineering Capability\n          </h2>\n          <p className={`mt-3.5 text-base md:text-lg font-light ${\n            isDark ? \'text-slate-400\' : \'text-slate-600\'\n          }`}>\n            Building scalable systems across Data, AI, Cloud and intelligent automation.\n          </p>\n        </div>\n\n        {/* --- DYNAMIC CAPABILITY CARDS --- */}\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-20\">\n          {sortedCategories.map((cat, i) => {\n            const isFeatured = i === 0;\n\n            return (\n              <motion.div\n                key={cat.title}\n                layout\n                className={`p-6 md:p-8 rounded-3xl border transition-all duration-500 shadow-sm relative overflow-hidden ${\n                  isFeatured \n                    ? isDark \n                      ? \'bg-neutral-900 border-indigo-500/20 shadow-[0_15px_30px_rgba(0,0,0,0.4)]\' \n                      : \'bg-white border-indigo-200 shadow-[0_15px_30px_rgba(31,38,135,0.04)]\'\n                    : isDark \n                      ? \'bg-neutral-900/60 border-neutral-900 hover:border-white/10\' \n                      : \'bg-white border-slate-200 hover:border-slate-300\'\n                }`}\n              >\n                {/* Active Highlight Glow for Top Category */}\n                {isFeatured && (\n                  <div className={`absolute top-0 right-0 w-24 h-24 rounded-full filter blur-[40px] opacity-20 ${\n                    isDark ? \'bg-indigo-400\' : \'bg-indigo-600\'\n                  }`} />\n                )}\n\n                <div className=\"flex items-center justify-between gap-3 mb-6 relative z-10\">\n                  <h3 className=\"text-lg font-bold font-display tracking-wide\">{cat.title}</h3>\n                  <span className={`text-[9px] uppercase font-mono tracking-widest font-semibold px-2 py-0.5 rounded-full ${\n                    isFeatured \n                      ? isDark ? \'bg-sky-500/10 text-sky-400\' : \'bg-indigo-50 text-indigo-700\'\n                      : isDark ? \'bg-neutral-800 text-slate-400\' : \'bg-slate-100 text-slate-500\'\n                  }`}>\n                    {isFeatured ? \'Primary Domain\' : `Rank #${cat.priority[currentMode]}`}\n                  </span>\n                </div>\n\n                <div className=\"space-y-3.5 relative z-10\">\n                  {cat.skills.map((skill) => (\n                    <div \n                      key={skill.name}\n                      style={{ contentVisibility: \'auto\' }}\n                      className={`flex items-center justify-between py-1 border-b border-dashed ${\n                        isDark ? \'border-neutral-800/60\' : \'border-slate-200/60\'\n                      }`}\n                    >\n                      <span className={`text-xs font-medium tracking-wide ${isDark ? \'text-slate-300\' : \'text-slate-700\'}`}>\n                        {skill.name}\n                      </span>\n                      <span className={`text-[10px] font-mono tracking-wider transition-all duration-300 ${\n                        skill.level === \'Expert\' \n                          ? \'text-sky-400 font-bold\' \n                          : skill.level === \'Advanced\' \n                            ? \'text-indigo-400 font-semibold\' \n                            : \'text-slate-400\'\n                      }`}>\n                        {skill.level}\n                      </span>\n                    </div>\n                  ))}\n                </div>\n              </motion.div>\n            );\n          })}\n        </div>\n\n        {/* --- PREMIUM CERTIFICATIONS WALL --- */}\n        <div className=\"mt-24\">\n          <div className=\"flex items-center gap-2 mb-3\">\n            <Award className={`w-4 .5 h-4.5 ${isDark ? \'text-sky-450\' : \'text-indigo-600\'}`} />\n            <h3 className=\"text-2xl font-display font-bold tracking-tight\">Verified Technical Credentials</h3>\n          </div>\n          <p className={`text-sm font-light mb-8 max-w-xl ${isDark ? \'text-slate-500\' : \'text-slate-600\'}`}>\n            Elite validation of cloud operations, automated AI pipeline development, and cognitive API orchestration.\n          </p>\n\n          <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6\">\n            {sortedCerts.map((cert) => (\n              <motion.div\n                key={cert.id}\n                layout\n                className={`p-6 rounded-2xl border transition-all duration-300 relative group overflow-hidden ${\n                  isDark \n                    ? \'bg-neutral-950 border-neutral-900 hover:border-neutral-800 hover:shadow-lg\' \n                    : \'bg-white border-slate-200/80 hover:border-slate-300 hover:shadow-md\'\n                }`}\n              >\n                {/* Micro branding stamp background */}\n                <div className={`absolute top-3 right-3 text-[11px] font-mono font-extrabold opacity-5 select-none ${\n                  isDark ? \'text-white\' : \'text-black\'\n                }`}>\n                  VERIFIED-ID\n                </div>\n\n                <div className=\"flex flex-col justify-between h-full\">\n                  <div>\n                    <span className={`text-[10px] font-mono font-semibold block uppercase tracking-wider mb-2.5 ${\n                      isDark ? \'text-sky-500\' : \'text-indigo-700\'\n                    }`}>\n                      {cert.issuer}\n                    </span>\n                    <h4 className=\"text-sm font-bold font-display tracking-wide mb-4 leading-snug\">\n                      {cert.title}\n                    </h4>\n                  </div>\n\n                  <div className={`pt-3.5 border-t border-dashed mt-2 flex items-center justify-between ${\n                    isDark ? \'border-neutral-900/60\' : \'border-slate-100/60\'\n                  }`}>\n                    <span className={`text-[10px] font-mono ${isDark ? \'text-slate-600\' : \'text-slate-400\'}`}>\n                      {cert.code ? `Code: ${cert.code}` : \'Reference Credential\'}\n                    </span>\n                    <span className={`text-[10px] font-mono font-medium px-2 py-0.5 rounded ${\n                      isDark ? \'bg-neutral-900 text-slate-400\' : \'bg-slate-100 text-slate-700\'\n                    }`}>\n                      {cert.date}\n                    </span>\n                  </div>\n                </div>\n              </motion.div>\n            ))}\n          </div>\n        </div>\n\n      </div>\n    </section>\n  );\n}\n"
    }
