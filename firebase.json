{
    "hosting":  {
                    "target":  "portfolio-main",
                    "public":  "frontend/dist",
                    "ignore":  [
                                   "firebase.json",
                                   "**/.*",
                                   "**/node_modules/**"
                               ],
                    "rewrites":  [
                                     {
                                         "source":  "/api/**",
                                         "run":  {
                                                     "serviceId":  "portfolio-backend",
                                                     "region":  "us-central1"
                                                 }
                                     },
                                     {
                                         "source":  "**",
                                         "destination":  "/index.html"
                                     }
                                 ]
                }
}
